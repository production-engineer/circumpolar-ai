# Get your Mapbox token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# Get your Anthropic API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenWeatherMap One Call API 3.0 — https://openweathermap.org/api/one-call-3
OPENWEATHER_API_KEY=your-owm-key

# Base URL for shareable site forecast links (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://circumpolar.ai
