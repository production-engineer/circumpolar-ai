# Get your Mapbox token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# Get your Anthropic API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# NextAuth — generate secret with: npx auth secret
AUTH_SECRET=your_secret_here

# GitHub OAuth app — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend email API — https://resend.com/api-keys
# Used to send acceptance confirmation emails
RESEND_API_KEY=re_your_key_here
