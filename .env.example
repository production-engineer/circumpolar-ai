# Get your Mapbox token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# Get your Anthropic API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# NextAuth — generate secret with: npx auth secret
AUTH_SECRET=your_secret_here

# GitHub OAuth app — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend email API — https://resend.com/api-keys
# Used to send acceptance confirmation emails
RESEND_API_KEY=re_your_key_here

# OpenWeatherMap Climate Forecast 30-day — https://openweathermap.org/api
OPENWEATHER_API_KEY=your-owm-key

# Base URL for shareable site links (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://circumpolar.ai
